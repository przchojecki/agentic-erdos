      {
        "script": "longterm_batch1_compute.mjs",
        "heading": ": bounded ordered representation greedy construction.",
        "extracted_section": "// EP-40: bounded ordered representation greedy construction.\n{\n  function boundedRepGreedy(N, R, seed) {\n    const rng = makeRng(seed);\n    const order = Array.from({ length: N }, (_, i) => i + 1);\n    shuffle(order, rng);\n    const rep = new Uint16Array(2 * N + 2);\n    const A = [];\n\n    for (const x of order) {\n      let ok = true;\n      for (const a of A) {\n        const s = a + x;\n        if (rep[s] + 2 > R) {\n          ok = false;\n          break;\n        }\n      }\n      if (!ok) continue;\n      const sx = x + x;\n      if (rep[sx] + 1 > R) continue;\n\n      for (const a of A) rep[a + x] += 2;\n      rep[sx] += 1;\n      A.push(x);\n    }\n    A.sort((a, b) => a - b);\n    return A;\n  }\n\n  const Ns = [2000, 5000, 10000];\n  const rows = [];\n  for (const N of Ns) {\n    for (const R of [2, 3]) {\n      let best = [];\n      for (let r = 0; r < 10; r += 1) {\n        const A = boundedRepGreedy(N, R, 20260304 ^ (N + R * 13 + r));\n        if (A.length > best.length) best = A;\n      }\n      rows.push({\n        N,\n        R,\n        size: best.length,\n        size_over_sqrtN: Number((best.length / Math.sqrt(N)).toPrecision(6)),\n      });\n    }\n  }\n\n  out.results.ep40 = {\n    description: 'Random-order greedy construction with bounded ordered representation r_A(n) <= R.',\n    rows,\n  };\n}"
      }
    ]
